rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.email == 'satyam.nigam2011@gmail.com';
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /notices/{noticeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /tickets/{ticketId} {
      allow read: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.userEmail == request.auth.token.email;
      allow update: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /playlists/{playlistId} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.creatorUid == request.auth.uid;
      allow update, delete: if isAdmin() || (signedIn() && resource.data.creatorUid == request.auth.uid);
    }

    match /users/{userId} {
      allow read, write: if isAdmin() || isOwner(userId);

      match /likes/{likeId} {
        allow read, write: if isAdmin() || isOwner(userId);
      }
    }

    match /adminAlbums/{albumId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /commonAlbums/{albumId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
